{
  "name": "@obscura/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.app.json --noEmit && vite build",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@ffmpeg/core": "0.12.9",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@imgly/background-removal": "^1.7.0",
    "@material-symbols-svg/react": "^0.10.1",
    "@obscura/media-core": "workspace:*",
    "@obscura/shared": "workspace:*",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tailwindcss/vite": "^4.1.17",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "comlink": "^4.4.2",
    "cropperjs": "^2.1.1",
    "gifenc": "1.0.3",
    "konva": "^10.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-konva": "^19.2.5",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.1.17",
    "utif2": "4.1.0",
    "zod": "^4.1.13",
    "zundo": "^2.3.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0"
  }
